<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Parcerias - Alpha WSX</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0d0d0d;
  color: #fff;
}

header {
  background: #111;
  padding: 20px;
  text-align: center;
  font-size: 26px;
  font-weight: bold;
  border-bottom: 2px solid #00ffcc;
}

.container {
  padding: 20px;
}

.section {
  margin-bottom: 40px;
}

.section h1 {
  font-size: 22px;
  margin-bottom: 15px;
  border-left: 5px solid #00ffcc;
  padding-left: 10px;
}

.card {
  background: #1a1a1a;
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 0 10px rgba(0,0,0,0.5);
}

.card h2 {
  margin: 0;
  color: #00ffcc;
}

.card p {
  color: #ccc;
  margin: 8px 0;
}

.buttons {
  margin-top: 10px;
}

.btn {
  display: inline-block;
  margin-right: 10px;
  padding: 8px 14px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: bold;
}

.site {
  background: #00ffcc;
  color: #000;
}

.insta {
  background: #e1306c;
  color: #fff;
}

.btn:hover {
  opacity: 0.8;
}

footer {
  text-align: center;
  padding: 15px;
  background: #111;
  color: #aaa;
}
</style>
</head>

<body>

<header>
🤝 Parcerias Oficiais
</header>

<div class="container">

<!-- PARCERIAS FIÉIS -->
<div class="section">
  <h1>🔹 Parcerias Fiéis</h1>

  <div class="card">
    <h2>Nome do Parceiro</h2>
    <p>Descrição do parceiro.</p>

    <div class="buttons">
      <a href="#" class="btn site">Site</a>
      <a href="https://instagram.com/" class="btn insta">Instagram</a>
    </div>
  </div>

</div>

<!-- PARCEIROS PREMIUM -->
<div class="section">
  <h1>⭐ Parceiros Premium</h1>

  <div class="card">
    <h2>Nome Premium</h2>
    <p>Descrição do parceiro premium.</p>

    <div class="buttons">
      <a href="#" class="btn site">Site</a>
      <a href="https://instagram.com/" class="btn insta">Instagram</a>
    </div>
  </div>

</div>

</div>

<footer>
© 2026 - Alpha WSX Accounts
</footer>

</body>
</html>
